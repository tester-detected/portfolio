			"name": "6. Заголовки ответов",
			"item": [
				{
					"name": "6.1 Проверка заголовков безопасности",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Content-Type — application/json', () => {",
									"    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
									"});",
									"",
									"pm.test('Есть X-Request-Id', () => {",
									"    pm.expect(pm.response.headers.has('X-Request-Id')).to.be.true;",
									"});",
									"",
									"pm.test('CORS не *', () => {",
									"    const cors = pm.response.headers.get('Access-Control-Allow-Origin');",
									"    if (cors) {",
									"        pm.expect(cors).to.not.eql('*');",
									"    }",
									"});",
									"",
									"pm.test('Strict-Transport-Security', () => {",
									"    pm.expect(pm.response.headers.has('Strict-Transport-Security')).to.be.true;",
									"});",
									"",
									"pm.test('Время ответа < 500ms', () => {",
									"    pm.expect(pm.response.responseTime).to.be.below(500);",
									"});"
