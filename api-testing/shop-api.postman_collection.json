{
	"info": {
		"name": "Shop API — QA Tests",
		"description": "Коллекция для тестирования REST API интернет-магазина.\n\nПеред запуском задайте переменные окружения:\n- `base_url` — URL сервера\n- `user_email` / `user_password` — данные тестового пользователя\n- `admin_email` / `admin_password` — данные администратора",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "https://api.shop.example.com/v1" },
		{ "key": "token", "value": "" },
		{ "key": "admin_token", "value": "" },
		{ "key": "product_id", "value": "" },
		{ "key": "order_id", "value": "" },
		{ "key": "user_email", "value": "testuser@example.com" },
		{ "key": "user_password", "value": "Passw0rd" },
		{ "key": "admin_email", "value": "admin@example.com" },
		{ "key": "admin_password", "value": "Adm1nPass" }
	],
	"item": [
		{
			"name": "1. Авторизация",
			"item": [
				{
					"name": "1.1 Логин — успешный",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 200', () => pm.response.to.have.status(200));",
									"",
									"pm.test('Ответ содержит access_token', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('access_token');",
									"    pm.expect(json).to.have.property('refresh_token');",
									"    pm.expect(json).to.have.property('expires_in');",
									"    pm.expect(json.expires_in).to.be.above(0);",
									"});",
									"",
									"pm.test('access_token — валидный JWT', () => {",
									"    const token = pm.response.json().access_token;",
									"    pm.expect(token.split('.')).to.have.lengthOf(3);",
									"});",
									"",
									"// Сохраняем токен для следующих запросов",
									"pm.collectionVariables.set('token', pm.response.json().access_token);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}"
						},
						"url": { "raw": "{{base_url}}/auth/login" }
					}
				},
				{
					"name": "1.2 Логин — неверный пароль",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 401', () => pm.response.to.have.status(401));",
									"",
									"pm.test('Нет токена в ответе', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.not.have.property('access_token');",
									"});",
									"",
									"pm.test('Сообщение не раскрывает детали', () => {",
									"    const json = pm.response.json();",
									"    const msg = (json.message || json.error || '').toLowerCase();",
									"    pm.expect(msg).to.not.include('password');",
									"    pm.expect(msg).to.not.include('пароль');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"wrongpassword\"\n}"
						},
						"url": { "raw": "{{base_url}}/auth/login" }
					}
				},
				{
					"name": "1.3 Логин — несуществующий email",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 401', () => pm.response.to.have.status(401));",
									"",
									"pm.test('Тот же текст ошибки, что и при неверном пароле', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.not.have.property('access_token');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"nobody@example.com\",\n  \"password\": \"Passw0rd\"\n}"
						},
						"url": { "raw": "{{base_url}}/auth/login" }
					}
				},
				{
					"name": "1.4 Логин — пустое тело",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 422', () => pm.response.to.have.status(422));",
									"",
									"pm.test('Ошибки валидации для обоих полей', () => {",
									"    const json = pm.response.json();",
									"    const errors = json.errors || json.detail || {};",
									"    pm.expect(JSON.stringify(errors)).to.include('email');",
									"    pm.expect(JSON.stringify(errors)).to.include('password');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{}"
						},
						"url": { "raw": "{{base_url}}/auth/login" }
					}
				},
				{
					"name": "1.5 Логин администратора",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 200', () => pm.response.to.have.status(200));",
									"",
									"pm.collectionVariables.set('admin_token', pm.response.json().access_token);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
						},
						"url": { "raw": "{{base_url}}/auth/login" }
					}
				},
				{
					"name": "1.6 Запрос без токена",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 401', () => pm.response.to.have.status(401));"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{base_url}}/products" }
					}
				}
			]
		},
		{
			"name": "2. Товары",
			"item": [
				{
					"name": "2.1 Список товаров",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 200', () => pm.response.to.have.status(200));",
									"",
									"pm.test('Ответ содержит items и pagination', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('items');",
									"    pm.expect(json).to.have.property('pagination');",
									"    pm.expect(json.items).to.be.an('array');",
									"});",
									"",
									"pm.test('Пагинация корректна', () => {",
									"    const p = pm.response.json().pagination;",
									"    pm.expect(p.page).to.eql(1);",
									"    pm.expect(p.per_page).to.eql(20);",
									"    pm.expect(p.total).to.be.at.least(0);",
									"});",
									"",
									"pm.test('Каждый товар имеет обязательные поля', () => {",
									"    const items = pm.response.json().items;",
									"    items.forEach(item => {",
									"        pm.expect(item).to.have.property('id');",
									"        pm.expect(item).to.have.property('name');",
									"        pm.expect(item).to.have.property('price');",
									"        pm.expect(item).to.have.property('stock');",
									"        pm.expect(item).to.have.property('category_id');",
									"    });",
									"});",
									"",
									"// Сохраняем ID первого товара",
									"const items = pm.response.json().items;",
									"if (items.length > 0) {",
									"    pm.collectionVariables.set('product_id', items[0].id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": { "raw": "{{base_url}}/products?page=1&per_page=20" }
					}
				},
				{
					"name": "2.2 Товар по ID",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 200', () => pm.response.to.have.status(200));",
									"",
									"pm.test('ID совпадает с запрошенным', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.id).to.eql(parseInt(pm.collectionVariables.get('product_id')));",
									"});",
									"",
									"pm.test('Цена положительная, остаток >= 0', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.price).to.be.above(0);",
									"    pm.expect(json.stock).to.be.at.least(0);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": { "raw": "{{base_url}}/products/{{product_id}}" }
					}
				},
				{
					"name": "2.3 Несуществующий товар",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 404', () => pm.response.to.have.status(404));"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": { "raw": "{{base_url}}/products/999999" }
					}
				},
				{
					"name": "2.4 Создание товара (admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 201', () => pm.response.to.have.status(201));",
									"",
									"pm.test('Ответ содержит ID', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('id');",
									"    pm.expect(json.name).to.eql('Тестовый товар QA');",
									"    pm.expect(json.price).to.eql(1500);",
									"});",
									"",
									"// Сохраняем ID для последующего удаления",
									"pm.collectionVariables.set('created_product_id', pm.response.json().id);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Тестовый товар QA\",\n  \"price\": 1500,\n  \"stock\": 100,\n  \"category_id\": 1,\n  \"description\": \"Создан автотестом\"\n}"
						},
						"url": { "raw": "{{base_url}}/products" }
					}
				},
				{
					"name": "2.5 Создание товара — невалидные данные",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 422', () => pm.response.to.have.status(422));",
									"",
									"pm.test('Ошибки для каждого поля', () => {",
									"    const body = JSON.stringify(pm.response.json());",
									"    pm.expect(body).to.include('name');",
									"    pm.expect(body).to.include('price');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"\",\n  \"price\": -100,\n  \"stock\": -5,\n  \"category_id\": 999999\n}"
						},
						"url": { "raw": "{{base_url}}/products" }
					}
				},
				{
					"name": "2.6 Создание товара без прав (user)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 403', () => pm.response.to.have.status(403));"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Хакерский товар\",\n  \"price\": 1,\n  \"stock\": 1,\n  \"category_id\": 1\n}"
						},
						"url": { "raw": "{{base_url}}/products" }
					}
				},
				{
					"name": "2.7 Удаление товара (admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 204', () => pm.response.to.have.status(204));"
								]
							}
						}
					],
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" }
						],
						"url": { "raw": "{{base_url}}/products/{{created_product_id}}" }
					}
				},
				{
					"name": "2.8 Повторное удаление (идемпотентность)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 404', () => pm.response.to.have.status(404));"
								]
							}
						}
					],
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" }
						],
						"url": { "raw": "{{base_url}}/products/{{created_product_id}}" }
					}
				}
			]
		},
		{
			"name": "3. Заказы",
			"item": [
				{
					"name": "3.1 Создание заказа",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 201', () => pm.response.to.have.status(201));",
									"",
									"pm.test('Заказ в статусе new', () => {",
									"    pm.expect(pm.response.json().status).to.eql('new');",
									"});",
									"",
									"pm.test('Сумма > 0', () => {",
									"    pm.expect(pm.response.json().total_amount).to.be.above(0);",
									"});",
									"",
									"pm.test('Содержит позиции', () => {",
									"    const items = pm.response.json().items;",
									"    pm.expect(items).to.be.an('array').with.lengthOf.at.least(1);",
									"});",
									"",
									"pm.collectionVariables.set('order_id', pm.response.json().id);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"items\": [\n    { \"product_id\": {{product_id}}, \"quantity\": 2 }\n  ]\n}"
						},
						"url": { "raw": "{{base_url}}/orders" }
					}
				},
				{
					"name": "3.2 Заказ — недостаточно на складе",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 422', () => pm.response.to.have.status(422));"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"items\": [\n    { \"product_id\": {{product_id}}, \"quantity\": 999999 }\n  ]\n}"
						},
						"url": { "raw": "{{base_url}}/orders" }
					}
				},
				{
					"name": "3.3 Пустой заказ",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 422', () => pm.response.to.have.status(422));"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"items\": []\n}"
						},
						"url": { "raw": "{{base_url}}/orders" }
					}
				},
				{
					"name": "3.4 Мои заказы",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 200', () => pm.response.to.have.status(200));",
									"",
									"pm.test('Ответ — массив с пагинацией', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('items');",
									"    pm.expect(json).to.have.property('pagination');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": { "raw": "{{base_url}}/orders?page=1&per_page=10" }
					}
				},
				{
					"name": "3.5 Отмена заказа",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 200', () => pm.response.to.have.status(200));",
									"",
									"pm.test('Статус заказа — cancelled', () => {",
									"    pm.expect(pm.response.json().status).to.eql('cancelled');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": { "raw": "{{base_url}}/orders/{{order_id}}/cancel" }
					}
				},
				{
					"name": "3.6 Повторная отмена",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 409 или 422', () => {",
									"    pm.expect(pm.response.code).to.be.oneOf([409, 422]);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": { "raw": "{{base_url}}/orders/{{order_id}}/cancel" }
					}
				}
			]
		},
		{
			"name": "4. Оплата",
			"item": [
				{
					"name": "4.1 Оплата заказа",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 200', () => pm.response.to.have.status(200));",
									"",
									"pm.test('Оплата завершена', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.status).to.eql('completed');",
									"    pm.expect(json.amount).to.be.above(0);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"method\": \"card\",\n  \"card_token\": \"tok_test_visa_4242\"\n}"
						},
						"url": { "raw": "{{base_url}}/orders/{{order_id}}/pay" }
					}
				},
				{
					"name": "4.2 Повторная оплата",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 409', () => pm.response.to.have.status(409));"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
